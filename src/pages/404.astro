---
import Anchor from "../components/base/Anchor.astro"
import Section from "../components/base/Section.astro"
import Layout from "../layouts/Layout.astro"
import { siteConfig } from "../config"
---

<Layout meta={{
  title: siteConfig.notFoundMeta.title,
  description: siteConfig.notFoundMeta.longDescription ?? siteConfig.notFoundMeta.description,
  url: new URL("/404", siteConfig.globalMeta.baseUrl).href,
}}>
  <Section class="mt-16">
    <h1 class="text-3xl sm:text-4xl font-display pb-8">
      Well, this is awkward
    </h1>
    <h2 class="text-xl sm:text-2xl pb-8">404 - Page not found</h2>
    <p>
      It seems that this page does not exist. If you want to return to safety, <Anchor url="/">click here to go home</Anchor>.
    </p>
  </Section>
</Layout>
