---
import Layout from "../layouts/Layout.astro"
import Section from "../components/base/Section.astro"
import { siteConfig } from "../config"
import { getChangelogContent } from "../lib/changelog"

// Read CHANGELOG.md at build time
const changelogContent = getChangelogContent()

const meta = {
  title: "Changelog",
  description:
    "Project changelog and version history for Alexander Fortin's personal website",
  url: `${siteConfig.globalMeta.baseUrl}/changelog`,
  keywords: ["changelog", "version history", "updates", "changes"],
}
---

<Layout meta={meta}>
  <Section class="my-4">
    <div class="text-center max-w-2xl mx-auto mt-8">
      <h1 class="text-3xl sm:text-4xl font-display font-semibold mb-4">
        Changelog
      </h1>
    </div>
  </Section>

  <Section class="my-6">
    <div
      class="prose dark:prose-invert max-w-none"
      set:html={changelogContent}
    />
  </Section>
</Layout>
