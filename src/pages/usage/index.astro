---
import Section from "../../components/base/Section.astro"
import Layout from "../../layouts/Layout.astro"
import { siteConfig } from "../../config"
import UsageApp from "../../components/usage/UsageApp.svelte"
---

<Layout meta={{
  title: `Usage — ${siteConfig.globalMeta.title}`,
  description: "Live usage and remaining balance for my LLM accounts.",
  url: Astro.url.href,
  keywords: ["usage", "llm", "api", "balance", "quota"],
}}>

  <Section class="mt-16">
    <noscript>
      <div class="text-center py-8 text-red-500 text-xl">
        Please enable JavaScript to view this page.
      </div>
    </noscript>

    <h1 class="text-3xl sm:text-4xl font-display pb-2 text-center">
      Usage
    </h1>
    <p class="text-center text-sm sm:text-base zag-muted mb-8">
      Current usage and remaining balance for my LLM accounts.
    </p>

    <UsageApp client:load />
  </Section>
</Layout>
