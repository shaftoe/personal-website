---
import { Temporal } from "temporal-polyfill"
import { siteConfig } from "../../config"

import packageJson from "../../../package.json"

const year = Temporal.Now.zonedDateTimeISO().year
const version = packageJson.version
---

<footer class="mt-16 mb-8">
  <nav class="zag-transition text-center text-sm max-w-2xl mx-auto">
    <ul class="grid grid-cols-3 sm:grid-cols-5 gap-x-4 gap-y-1">
      {[...siteConfig.slashPages].sort((a, b) => a.label.localeCompare(b.label)).map(({ label }) => {
        const href = `/${label}`
        return (
        <li>
          <a class="zag-text hover:underline capitalize" href={href}>
            /{label}
          </a>
        </li>
        )
      })}
    </ul>
  </nav>
  <p class="zag-text zag-transition mt-4 text-center text-sm font-medium flex justify-center items-center gap-x-2 flex-col sm:flex-row">
    <span>&copy; {year} {siteConfig.globalMeta.name}</span>
    <span class="hidden sm:inline" aria-hidden="true">|</span>
    <span><a class="hover:underline" href={`/changelog#${version}`}>v{version}</a></span>
  </p>
</footer>
