---
import { processArticleDate } from "../../lib/utils"
import Anchor from "../base/Anchor.astro"
import TagList from "./TagList.astro"

export type Props = {
  title: string
  url: string
  description?: string
  duration?: string
  timestamp?: Date
  tags?: string[]
}

const { title, description, url, duration, timestamp, tags } = Astro.props

/**
 * Converts a human-readable duration like "4 min" to ISO 8601 duration "PT4M".
 */
const durationToISO = (d: string): string => {
  const match = d.match(/(\d+)\s*min/)
  if (match) return `PT${match[1]}M`
  return `PT0M`
}
---

<article class="h-entry relative zag-text zag-transition flex flex-col gap-3 mb-8 hover-zag-dotted-grid">
  <a class="u-url hidden" href={url} aria-hidden="true"></a>
  {description && <data class="p-summary hidden" value={description} aria-hidden="true"></data>}
  <h3 class="text-xl p-name">
    <Anchor url={url}>
      {title}
    </Anchor>
  </h3>
  {description && <p class="p-summary">{description}</p>}
  <footer class="zag-muted zag-transition flex flex-wrap gap-x-3 gap-y-1 items-center">
    {timestamp ? <time class="dt-published" datetime={timestamp.toISOString()}>{processArticleDate(timestamp)}</time> : null}
    {duration ? <time datetime={durationToISO(duration)}>{duration}</time> : null}
    {tags && <TagList tags={tags} microformats={true} />}
  </footer>
</article>
