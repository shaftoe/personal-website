---
import { processArticleDate } from "../lib/utils"
import Anchor from "./common/Anchor.astro"
import TagList from "./common/TagList.astro"

export type Props = {
  title: string
  url: string
  description?: string
  duration?: string
  timestamp?: Date
  tags?: string[]
}

const { title, description, url, duration, timestamp, tags } = Astro.props
---

<article class="relative zag-text zag-transition flex flex-col gap-3 mb-8 hover-zag-dotted-grid">
  <h3 class="text-xl">
    <Anchor url={url}>
      {title}
    </Anchor>
  </h3>
  {description && <p class="">{description}</p>}
  <footer class="zag-muted zag-transition flex flex-wrap gap-x-3 gap-y-1 items-center">
    {timestamp ? <time datetime={timestamp.toISOString()}>{processArticleDate(timestamp)}</time> : null}
    {duration ? <time>{duration}</time> : null}
    {tags && <TagList tags={tags} />}
  </footer>
</article>
