---
import Layout from "./Layout.astro"

type Props = {
  frontmatter: {
    title: string
    description: string
    url?: string
    keywords?: string[]
  }
  subtitle?: string
}

const { frontmatter, subtitle } = Astro.props
---

<Layout meta={{
  title: frontmatter.title,
  description: frontmatter.description,
  url: Astro.url.href,
  keywords: frontmatter.keywords,
}}>
  <div class="px-4 text-center max-w-2xl mx-auto my-16">
    <h1 class="text-3xl sm:text-4xl font-display font-semibold mb-4">
      {frontmatter.title}
    </h1>
    {subtitle && (
      <p class="text-xl sm:text-2xl font-mono font-medium text-center">
        {subtitle}
      </p>
    )}
  </div>

  <div class="px-4 max-w-2xl mx-auto prose dark:prose-invert">
    <slot />
  </div>
</Layout>
