---
import Section from "../components/base/Section.astro"
import TagList from "../components/blog/TagList.astro"
import Prose from "../components/base/Prose.astro"
import JsonLd from "../components/layout/JsonLd.astro"
import type { ArticleFrontmatter } from "../lib/blog-collection"
import { toInstant, processArticleDate } from "../lib/utils"
import { siteConfig } from "../config"
import { blogPostingSchema } from "../lib/jsonld"
import { getDocumentUri } from "../lib/standard"
import Layout from "./Layout.astro"

type Props = { frontmatter: ArticleFrontmatter }

const { frontmatter } = Astro.props
const timestamp = toInstant(frontmatter.timestamp)
const articleDate = processArticleDate(timestamp)

// Standard.site document AT URI for this article (from the committed
// sidecar). Present only after `bun run standard:documents` has been run;
// renders a discoverability <link> in the page head when available.
const standardDocumentUri = frontmatter.slug
  ? getDocumentUri(frontmatter.slug)
  : null
---

<Layout meta={{
  title: `${frontmatter.title} • ${siteConfig.globalMeta.name}`,
  description: frontmatter.longDescription ?? frontmatter.description ?? "",
  url: Astro.url.href,
  keywords: frontmatter.tags,
  image: frontmatter.cardImage,
  type: "article",
}}>
  <JsonLd data={blogPostingSchema(frontmatter, Astro.url.href)} slot="head" />
  {standardDocumentUri && (
    <link rel="site.standard.document" href={standardDocumentUri} slot="head" />
  )}
  <Section class="pt-8 h-entry">
    <a class="u-url hidden" href={Astro.url.href} aria-hidden="true"></a>
    <data class="p-uid hidden" value={Astro.url.href} aria-hidden="true"></data>
    {frontmatter.description && (
      <data class="p-summary hidden" value={frontmatter.description} aria-hidden="true"></data>
    )}
    <div class="flex flex-col gap-4 mt-8 mb-16">
      <h1
        class="text-3xl sm:text-4xl leading-normal sm:leading-normal font-display p-name"
      >
        {frontmatter.title}
      </h1>
      <div class="flex flex-wrap justify-between items-center gap-y-3">
        <time class="dt-published" datetime={timestamp.toString()}>{articleDate}</time>
        <span>{frontmatter.readTime} min</span>
        {frontmatter.tags && <TagList tags={frontmatter.tags} microformats={true} />}
      </div>
    </div>
    <div class="e-content">
      <Prose>
        <slot />
      </Prose>
    </div>
    <p class="pt-8 p-author h-card">~{siteConfig.globalMeta.name}</p>
  </Section>
</Layout>
