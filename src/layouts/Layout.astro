---
import Footer from "../components/layout/Footer.astro"
import HeadMeta from "../components/layout/HeadMeta.astro"
import Header from "../components/layout/Header.astro"
import { siteConfig } from "../config"
import "../styles/global.css"

type Meta = {
  title: string
  description: string
  url: string
  keywords?: string[]
  image?: string
  type?: "website" | "article"
}

type Props = {
  meta: Meta
}

const { meta } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="alternate" type="application/rss+xml" title="Blog RSS Feed" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f5f5f5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171717" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <!-- Theme detection script - runs before page renders -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          return localStorage.getItem("theme") ?? "light";
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }

      window.localStorage.setItem("theme", theme);
    </script>

    <!-- Umami analytics - disabled in dev, disabled on /expenses when authenticated -->
    {import.meta.env.PROD && (
      <script is:inline data-umami-src={siteConfig.analytics.umami.src} data-umami-id={siteConfig.analytics.umami.websiteId}>
        const skipAnalytics =
          location.pathname === "/expenses" &&
          !!localStorage.getItem("expenses-password");
        if (!skipAnalytics) {
          const s = document.createElement("script");
          s.defer = true;
          s.src = document.currentScript.dataset.umamiSrc;
          s.dataset.websiteId = document.currentScript.dataset.umamiId;
          document.head.appendChild(s);
        }
      </script>
    )}

    <HeadMeta {...meta} />
    <slot name="head" />
  </head>
  <body class="zag-bg zag-text zag-transition font-mono">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
