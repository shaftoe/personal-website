{
  "name": "alexanderfortin-personal-website",
  "type": "module",
  "version": "1.21.2",
  "private": true,
  "scripts": {
    "dev": "astro dev --open",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "clean": "rm -rf dist",
    "lint": "biome check src scripts",
    "lint:fix": "biome check --fix src scripts",
    "format": "biome format src scripts",
    "format:fix": "biome format --fix src scripts",
    "test": "bun test tests/*.test.ts",
    "test:unit": "bun test tests/utils.test.ts tests/blog-collection.test.ts tests/mastodon-helpers.test.ts",
    "test:html": "bun test tests/html-validation.test.ts",
    "validate": "bun run lint && bun run format && bun run check",
    "build:tracker": "sed \"s|__COLLECT_API_HOST__|https://cloud.umami.is|g; s|__COLLECT_API_ENDPOINT__|/api/send|g\" umami/src/tracker/index.js > public/scripts/umami.js",
    "blog-posts": "bun run scripts/blog-posts.ts",
    "changelog": "bun run scripts/changelog.ts",
    "postroll": "bun run scripts/postroll.ts",
    "release": "semantic-release"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/svelte": "8.1.2",
    "@lucide/astro": "^1.20.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "marked": "^18.0.5",
    "svelte": "^5.56.3",
    "tailwindcss": "^4.3.1",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@alexanderfortin/semantic-release-keep-a-changelog": "^0.4.2",
    "@astrojs/check": "0.9.9",
    "@astrojs/ts-plugin": "1.10.9",
    "@biomejs/biome": "^2.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "1.3.14",
    "@types/node": "^25.9.3",
    "gray-matter": "^4.0.3",
    "semantic-release": "^25.0.5",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "vnu-jar": "^26.6.14"
  }
}
