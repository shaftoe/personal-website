{
  "name": "alexanderfortin-personal-website",
  "type": "module",
  "version": "1.1.2",
  "private": true,
  "scripts": {
    "dev": "astro dev --open",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format .",
    "format:fix": "biome format --fix .",
    "validate": "bun run lint && bun run format && bun run check",
    "blog-posts": "bun run scripts/blog-posts.ts",
    "changelog": "bun run scripts/changelog.ts",
    "release": "semantic-release"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.0.4",
    "@lucide/astro": "^1.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "marked": "^18.0.0",
    "svelte": "^5.55.3",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.11",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.6.0",
    "gray-matter": "^4.0.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2"
  }
}
